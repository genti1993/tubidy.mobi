<!DOCTYPE html>
<html lang="sq">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Tubidy ju lejon të shkarkoni dhe të dëgjoni muzikë dhe video falas. Shijoni muzikë MP3 320kbps dhe video MP4 të cilësisë së lartë.">
    <meta name="robots" content="index, follow">
    <title>Tubidy - Shkarkime MP3 & MP4 | Muzikë dhe Video Falas Online</title>
    
    <!-- Metadata për Rrjetet Sociale (Open Graph) -->
    <meta property="og:locale" content="sq_AL">
    <meta property="og:type" content="website">
    <meta property="og:title" content="Tubidy - Shkarkime MP3 & MP4 | Muzikë dhe Video Falas Online">
    <meta property="og:description" content="Tubidy ju lejon të shkarkoni dhe të dëgjoni muzikë dhe video falas.">
    <meta property="og:url" content="https://tubidy.llc">
    <meta property="og:site_name" content="Tubidy">
    <meta property="og:image" content="https://tubidy.llc">
    <link href="https://tubidy.llc" rel="canonical">
    
    <!-- Lidhja me Stilet -->
    <link rel="stylesheet" href="styles.css">

    <!-- Kodi për Modalitetin e Errët (Dark Mode) -->
    <script>
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body>
    <header>
      <img src="https://tubidy.llc" alt="Tubidy Logo" class="logo">
      <h1>Kërko Muzikë dhe Video</h1>
    </header>

    <main>
      <!-- Fusha e Kërkimit -->
      <form action="#" method="GET" class="search-form" onsubmit="event.preventDefault(); alert('Kërkimi u krye!');">
        <input type="text" name="q" placeholder="Shkruaj artistin, këngën ose videon..." required autocomplete="off" class="search-input">
        <button type="submit" class="search-button">Kërko</button>
      </form>
      <p class="subtitle">Kërkoni, dëgjoni dhe shkarkoni mediat tuaja të preferuara falas.</p>

      <!-- PLAYER-I I MUZIKËS (Rreshti 47) -->
      <div style="margin-top: 30px; text-align: center;">
        <h3>Duke luajtur: Marin - Audio Hit #1</h3>
        <audio id="myPlayer" src="audio/hit1.mp3" controls></audio>
      </div>

    </main>
  </body>
</html>
