<!DOCTYPE html>
<html lang="sq">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Tubidy ju lejon të shkarkoni dhe të dëgjoni muzikë dhe video falas. Shijoni muzikë MP3 320kbps dhe video MP4 të cilësisë së lartë.">
    <meta name="robots" content="index, follow">
    <title>Tubidy - Player Universal i Muzikës</title>
    
    <!-- Lidhja me Stilet -->
    <link rel="stylesheet" href="styles.css">

    <!-- Kodi për Modalitetin e Errët (Dark Mode) -->
    <script>
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body>
    <header style="text-align: center; padding: 20px;">
      <h1>Tubidy - Luaj Çdo Muzikë</h1>
    </header>

    <main style="max-width: 500px; margin: 0 auto; padding: 20px; font-family: Arial, sans-serif;">
      
      <!-- Fusha e Kërkimit -->
      <form action="#" method="GET" class="search-form" onsubmit="kerkoDheLuaj(event);" style="display: flex; gap: 10px; margin-bottom: 20px;">
        <input type="text" id="inputKerkimi" placeholder="Shkruaj emrin e këngës ose artistit..." required autocomplete="off" style="flex: 1; padding: 10px; border: 1px solid #ccc; border-radius: 5px;">
        <button type="submit" style="background: #28a745; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; font-weight: bold;">▶ Luaj</button>
      </form>
      
      <p class="subtitle" style="text-align: center; color: #666;">Shkruani çfarëdo kënge më lart dhe shtypni butonin për ta dëgjuar.</p>

      <!-- PLAYER-I UNIVERSAL -->
      <div id="playerBox" style="margin-top: 30px; text-align: center; padding: 20px; border: 1px solid #ddd; background: #f9f9f9; border-radius: 10px; display: none;">
        <h3 id="titulliKenges" style="margin-bottom: 15px; color: #333;">Duke luajtur...</h3>
        
        <!-- Ky element do të ngarkojë audion/videon në mënyrë automatike -->
        <div id="videoContainer" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 5px;">
          <iframe id="youtubeIframe" src="" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;" allow="autoplay; encrypted-media" autoplay></iframe>
        </div>
      </div>

    </main>

    <!-- KODI QË MUNDËSON LUAJTJEN E ÇDO KËNGE -->
    <script>
      function kerkoDheLuaj(event) {
        event.preventDefault(); // Ndalon rifreskimin e faqes
        
        var kenga = document.getElementById('inputKerkimi').value;
        var playerBox = document.getElementById('playerBox');
        var titulli = document.getElementById('titulliKenges');
        var iframe = document.getElementById('youtubeIframe');
        
        if(kenga.trim() !== "") {
          // Ndryshon titullin në ekran
          titulli.innerText = "Duke luajtur: " + kenga;
          
          // Përdor shërbimin e kërkimit të hapur të YouTube pa pasur nevojë për çelës privat API
          var urlKerkimi = "https://youtube.com" + encodeURIComponent(kenga) + "&autoplay=1";
          
          // Vendos linun e ri te player-i
          iframe.src = urlKerkimi;
          
          // Shfaq player-in në ekran
          playerBox.style.display = "block";
        }
      }
    </script>
  </body>
</html>
